# ─────────────────────────────────────────────────────────────────────────────
# Bhoomi Care — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API key  (used for AI Assistant + Community AI responses)
# Get a free key → https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Override the API base URL.
# Leave empty in production — Vercel serves /api/* as serverless functions.
# For local dev the Vite proxy forwards /api/* to http://localhost:5000.
VITE_API_URL=
