# Server Configuration
PORT=5000

# MongoDB Connection String (Required)
# e.g., mongodb+srv://username:password@cluster.mongodb.net/bhoomicare
MONGODB_URI=your_mongodb_connection_string_here

# JWT Secret for User Authentication (Required)
# Generate a secure random string for this
JWT_SECRET=your_jwt_secret_key_here

# Razorpay Keys for Payment Integration (Optional for local testing)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret