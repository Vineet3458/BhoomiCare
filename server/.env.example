# Server Configuration
PORT=5000

# MongoDB Connection String (Required)
# e.g., mongodb+srv://username:password@cluster.mongodb.net/bhoomicare
MONGODB_URI=your_mongodb_connection_string_here

# JWT Secret for User Authentication (Required)
# Generate a secure random string for this
JWT_SECRET=your_jwt_secret_key_here

# Gemini AI API Key (Required for AI Chatbot)
# Get your FREE key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Razorpay Keys for Payment Integration (Optional — mock logic used if absent)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret